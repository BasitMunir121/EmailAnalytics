<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ExSign Analytics</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="app-shell">
    <header class="topbar">
        <div class="brand">
            <span class="brand-logo" aria-hidden="true">
                <svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect width="36" height="36" rx="8" fill="#F1F3F8"/>
                    <path d="M8 12.5C8 11.6716 8.67157 11 9.5 11H26.5C27.3284 11 28 11.6716 28 12.5V23.5C28 24.3284 27.3284 25 26.5 25H9.5C8.67157 25 8 24.3284 8 23.5V12.5Z" fill="#E8EEF8" stroke="#3B82F6" stroke-width="1.6"/>
                    <path d="M9 12.5L18 18.5L27 12.5" stroke="#3B82F6" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M22.5 20.5C23.8 21.1 25.4 22.6 26 24.2" stroke="#EF4444" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M24.2 19.8L26.5 22.8L28.2 19.2" stroke="#EF4444" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </span>
            <span class="brand-text">
                <span class="brand-name">ExSign Analytics</span>
                <span class="brand-tag">Email Signatures Analytics</span>
            </span>
        </div>
        <div class="top-actions">
            <button type="button" class="top-icon-btn" title="Notifications" aria-label="Notifications">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M12 22a2.2 2.2 0 0 0 2.2-2.2h-4.4A2.2 2.2 0 0 0 12 22Z" fill="#3F4254"/>
                    <path d="M18.5 16.2V11a6.5 6.5 0 1 0-13 0v5.2l-1.4 1.6c-.4.45-.08 1.2.52 1.2h15.76c.6 0 .92-.75.52-1.2l-1.4-1.6Z" fill="#3F4254"/>
                </svg>
                <span class="badge-dot">1</span>
            </button>
            <button type="button" class="top-avatar-btn" title="Profile" aria-label="Profile">
                <svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <rect width="36" height="36" rx="8" fill="#E4E6EF"/>
                    <circle cx="18" cy="14" r="5" fill="#A1A5B7"/>
                    <path d="M8.5 28.5c1.8-4.2 5.2-6.5 9.5-6.5s7.7 2.3 9.5 6.5" fill="#A1A5B7"/>
                </svg>
            </button>
        </div>
    </header>

    <div class="layout">
        <aside class="sidebar">
            <div class="sidebar-section">
                <ul class="sidebar-nav">
                    <li>
                        <a asp-controller="Dashboard" asp-action="Index"
                           class="@(ViewData["Nav"]?.ToString() == "Dashboard" ? "active" : null)">
                            <span class="nav-icon" aria-hidden="true">
                                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <rect x="1.5" y="1.5" width="6.5" height="6.5" rx="1.5" fill="currentColor" class="nav-icon-primary" />
                                    <rect x="10" y="1.5" width="6.5" height="6.5" rx="1.5" fill="currentColor" class="nav-icon-muted" />
                                    <rect x="1.5" y="10" width="6.5" height="6.5" rx="1.5" fill="currentColor" class="nav-icon-muted" />
                                    <rect x="10" y="10" width="6.5" height="6.5" rx="1.5" fill="currentColor" class="nav-icon-muted" />
                                </svg>
                            </span>
                            <span class="nav-text">Dashboard</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Signatures" asp-action="Index"
                           class="@(ViewData["Nav"]?.ToString() == "Signatures" ? "active" : null)">
                            <span class="nav-icon" aria-hidden="true">
                                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M3 4.5h12M3 9h12M3 13.5h8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" class="nav-icon-muted"/>
                                    <path d="M12.5 12.2l2.2 1.1-1.1-2.2 3.4-3.4a1.1 1.1 0 0 0-1.55-1.55L12.5 12.2z" fill="currentColor" class="nav-icon-primary"/>
                                </svg>
                            </span>
                            <span class="nav-text">Signatures</span>
                        </a>
                    </li>
                </ul>
            </div>
        </aside>

        <main class="content">
            @if (TempData["Error"] != null)
            {
                <div class="alert">@TempData["Error"]</div>
            }
            @RenderBody()
        </main>
    </div>
</div>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
