@{
	var parent = ViewData["BreadcrumbParent"]?.ToString();
	var current = ViewData["BreadcrumbCurrent"]?.ToString() ?? ViewData["Title"]?.ToString() ?? "";
	var parentIsDashboard = string.Equals(parent, "Dashboard", StringComparison.OrdinalIgnoreCase);
}
<div class="breadcrumb">
	@if (!string.IsNullOrEmpty(parent))
	{
		@if (parentIsDashboard)
		{
			<a asp-controller="Dashboard" asp-action="Index" class="breadcrumb-item breadcrumb-link">@parent</a>
		}
		else
		{
			<span class="breadcrumb-item">@parent</span>
		}
	}
	<span class="breadcrumb-sep"></span>
	<span class="breadcrumb-item breadcrumb-current">@current</span>
</div>
