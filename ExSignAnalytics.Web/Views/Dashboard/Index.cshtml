@model List<ExSignAnalytics.Web.Models.TrackingSummaryViewModel>

<div class="page-header">
    <div>
        <h1 class="page-title">Dashboard</h1>
    </div>
    <div class="page-actions">
        <a class="btn btn-primary" asp-action="Index">Refresh</a>
        <form asp-action="ClearAll" method="post" onsubmit="return confirm('Delete ALL tracking data?');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-ghost">Clear All</button>
        </form>
    </div>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert">@ViewBag.Error</div>
}

@if (Model == null || Model.Count == 0)
{
    <div class="empty-state">No tracking IDs yet. Opens and clicks will appear here once emails are tracked.</div>
}
else
{
    <div class="card-grid">
        @foreach (var item in Model)
        {
            <div class="report-card">
                <h3>@item.TrackingId</h3>
                <div class="card-stats">
                    Opens: <strong>@item.OpenCount</strong><br />
                    Clicks: <strong>@item.ClickCount</strong>
                </div>
                <p class="card-desc">View open and click activity for this tracking ID.</p>
                <div class="card-footer">
                    <a class="btn btn-primary"
                       asp-action="Details"
                       asp-route-id="@item.TrackingId">View</a>
                </div>
            </div>
        }
    </div>
}
